{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "BitFun",
    "identifier": "com.bitfun.desktop",
    "build": {
        "beforeDevCommand": "npm run dev:web",
        "devUrl": "http://localhost:1422",
        "frontendDist": "../../../dist"
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "app": {
        "windows": [{
            "title": "tauri-demo",
            "width": 800,
            "height": 600
        }],
        "security": {
            "csp": null
        }
    }
}